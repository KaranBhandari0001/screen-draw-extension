{
  "manifest_version": 3,
  "name": "Simple Screen Draw",
  "version": "1.0",
  "description": "Draw on any website with a floating button",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
